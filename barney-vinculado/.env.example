# Ambiente
NODE_ENV=development
PORT=3333

# Banco de dados
# Desenvolvimento simples com SQLite:
DATABASE_URL="file:./dev.db"
# Produção recomendada com Postgres:
# DATABASE_URL="postgresql://usuario:senha@host:5432/barney?schema=public"

# Segurança - troque antes de publicar
JWT_SECRET="troque-por-uma-chave-com-mais-de-32-caracteres"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_DAYS=7

# CORS - coloque o domínio real do seu front-end em produção
CORS_ORIGIN="http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173"

# Criptografia de CPF/telefone
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY="troque-por-uma-chave-base64-de-32-bytes"

# Administrador inicial
ADMIN_EMAIL="admin@barney.com"
ADMIN_PASSWORD="admin123456"
ADMIN_NAME="Administrador Barney"

# Pix
PIX_KEY="34992488336"
PIX_MERCHANT_NAME="KAUAN PEREIRA DE OLIVEIRA"
PIX_MERCHANT_CITY="IGARAPE"

# Integrações futuras
OPENAI_API_KEY=""
WHATSAPP_API_TOKEN=""
